# Copy this file to .env and fill in your values.

# URL of the running LexAI FastAPI backend.
# Default works if you started it locally with uvicorn api:app --port 8000.
LEXAI_BACKEND_URL=http://localhost:8000

# Your owner_id — the one used when you upload documents to LexAI.
# Find it by checking the owner_id you pass in the React frontend,
# or query the chroma_store SQLite directly:
#   SELECT DISTINCT string_value FROM embedding_metadata WHERE key='owner_id';
LEXAI_OWNER_ID=your-owner-id-here
